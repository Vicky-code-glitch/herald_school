<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.simplecss.org/simple.min.css">
    <title>My Submissions</title>
    <style>
        .grade-pass { 
            color: #28a745; 
            font-weight: bold; 
        }
        .grade-fail { 
            color: #dc3545; 
            font-weight: bold; 
        }
    </style>
</head>
<body>
    <header>
        <h1>My Submissions</h1>
        <nav>
            <a href="/students/dashboard">Dashboard</a> |
            <a href="/students/assignments">Assignments</a> |
            <a href="/students/my-submissions">My Submissions</a> |
            <a href="/logout">Logout</a>
        </nav>
    </header>
    
    <main>
        <h2>All My Submissions</h2>
        
        <% if (submissions.length === 0) { %>
            <p>You haven't submitted any assignments yet.</p>
            <a href="/students/assignments">View Available Assignments</a>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Assignment</th>
                        <th>Submitted On</th>
                        <th>File</th>
                        <th>Grade</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% submissions.forEach(sub => { %>
                        <tr>
                            <td><%= sub.assignmentId.title %></td>
                            <td><%= new Date(sub.submittedAt).toLocaleString() %></td>
                            <td><a href="<%= sub.fileUrl %>" target="_blank"><%= sub.originalFileName %></a></td>
                            <td class="<%= sub.grade && sub.grade >= 50 ? 'grade-pass' : (sub.grade ? 'grade-fail' : '') %>">
                                <%= sub.grade ? sub.grade + '%' : 'Not graded' %>
                            </td>
                            <td><%= sub.status %></td>
                            <td>
                                <% if (!sub.grade && sub.status !== 'graded') { %>
                                    <button onclick="deleteSubmission('<%= sub._id %>')" style="background: #dc3545; color: white;">Delete</button>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </main>
    
    <script>
        async function deleteSubmission(submissionId) {
            if (confirm('Are you sure you want to delete this submission? This cannot be undone.')) {
                const response = await fetch(`/students/submissions/${submissionId}`, {
                    method: 'DELETE'
                });
                
                const result = await response.json();
                if (result.success) {
                    alert('Submission deleted successfully');
                    location.reload();
                } else {
                    alert('Error: ' + result.message);
                }
            }
        }
    </script>
</body>
</html>